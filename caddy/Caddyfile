www.llmastro.com {
redir https://llmastro.com{uri} permanent
}

llmastro.com {
# SECURITY-FAIL2BAN-CADDY-V1 — access-log JSON vers un fichier monté sur l'hôte
# (/var/log/caddy/access.log) pour que fail2ban puisse bannir les IP abusives
# (429 répétés, 401/403 sur /api/auth/*). Rotation interne Caddy (taille + nb).
log {
output file /var/log/caddy/access.log {
roll_size 20MiB
roll_keep 5
roll_keep_for 336h
}
format json
}
encode gzip zstd
handle_path /api/* {
reverse_proxy api:4000
}
# SOCIAL-AUTOPOST-API-A1 — sert les images du « ciel du jour » en HTTPS public.
# Requis par l'API Instagram (Meta télécharge l'image via cURL depuis une URL publique ;
# Pinterest n'en a pas besoin, on l'envoie en base64). Dossier monté lecture seule depuis
# l'hôte : ./scripts/social/out -> /srv/social (cf. docker-compose.prod.yml).
# Ex : https://llmastro.com/social/2026-06-24/ciel-day-2026-06-24.jpg
# Les en-têtes de sécurité globaux (CSP, X-Frame-Options…) s'appliquent aussi ici : sans
# effet sur un GET image fetché côté serveur. Pas de `browse` → aucune liste de répertoire.
handle_path /social/* {
root * /srv/social
file_server
}
# PWA-OFFLINE-V1 — le Service Worker ne doit jamais être figé par un cache edge,
# sinon les navigateurs gardent l'ancienne version jusqu'à 24h. On REMPLACE
# (header_down, pas un header global qui s'ajouterait au Cache-Control de Next
# → doublon, cf. SECURITY-HEADERS-DEDUPE-V1).
@sw path /sw.js
handle @sw {
reverse_proxy web:3000 {
# Set (sans préfixe) = remplace le Cache-Control amont de Next. NE PAS utiliser
# `-Cache-Control` : les ops s'appliquent Add→Set→Delete, le delete passerait
# après et supprimerait aussi la valeur posée ici.
header_down Cache-Control "no-cache, no-store, must-revalidate"
}
}
@securitytxt path /.well-known/security.txt /security.txt
handle @securitytxt {
header Content-Type "text/plain; charset=utf-8"
respond `Contact: https://llmastro.com/contact
Expires: 2027-06-11T00:00:00.000Z
Preferred-Languages: fr, en
Canonical: https://llmastro.com/.well-known/security.txt
` 200
}
# UMAMI-ANALYTICS-V1 — COLLECTE d'audience privacy-first servie EN FIRST-PARTY
# same-origin : le script (/mz/script.js) et l'envoi (/mz/api/send) passent par
# llmastro.com → non bloqués par les adblockers, AUCUNE modif CSP. `handle_path`
# STRIPPE le préfixe /mz car Umami sert à la racine (BASE_PATH build-time ignoré
# au runtime en v3). Le front pose data-host-url="https://llmastro.com/mz" pour
# que la collecte cible /mz/api/send. Le DASHBOARD admin est servi à part
# (sous-domaine, cf. bloc dédié) car son Next.js exige la racine.
handle_path /mz/* {
reverse_proxy umami:3000
}
handle {
reverse_proxy web:3000
}
header {
# SECURITY-HEADERS-DEDUPE-V1 — source de vérité UNIQUE des en-têtes de
# sécurité (Next n'en pose plus, cf. apps/web/next.config.mjs).
Strict-Transport-Security "max-age=31536000; includeSubDomains"
X-Content-Type-Options "nosniff"
X-Frame-Options "DENY"
Referrer-Policy "strict-origin-when-cross-origin"
Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
Cross-Origin-Opener-Policy "same-origin"
Cross-Origin-Resource-Policy "same-origin"
# SECURITY-CSP-V1 — Content-Security-Policy. App 100% same-origin (aucune CDN,
# polices/Stripe.js/SDK OAuth non chargés ; social login = redirection serveur
# /api/auth/* donc hors champ CSP). 'unsafe-inline' requis car Next émet des
# scripts inline d'hydratation et Caddy ne peut pas injecter de nonce par requête
# (passage à nonce+strict-dynamic = chantier app-level). Vérifié en Report-Only
# (0 violation : accueil, pages marketing, /auth/*, dashboard authentifié) avant
# bascule en mode bloquant. ⚠️ bind-mount fichier unique : éditer ce fichier change
# l'inode → `docker restart astro-platform-caddy-1` requis (un reload ne suffit pas).
# SECURITY-CSP-GTM-V1 — ajout des domaines Google Tag Manager / Analytics 4
# (ANALYTICS-GTM-V1). GTM sert son loader + gtag.js depuis googletagmanager.com ;
# GA4 collecte via google-analytics.com et ses variantes régionales
# (*.google-analytics.com, *.analytics.google.com). Le <noscript> GTM charge une
# iframe googletagmanager.com/ns.html → frame-src. 'unsafe-inline' (déjà présent)
# couvre les scripts inline injectés par GTM. Étendre ces listes si de nouveaux
# tags (Ads, Floodlight, pixels tiers…) sont ajoutés dans le container GTM.
Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com; font-src 'self' data:; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; worker-src 'self'; manifest-src 'self'; form-action 'self'; frame-src 'self' https://www.googletagmanager.com; upgrade-insecure-requests"
-X-Powered-By
}
}
