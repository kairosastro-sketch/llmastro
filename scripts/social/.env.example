# SOCIAL-AUTOPOST-API-A1 — config de publish.mjs
# Copier en `.env` (gitignoré) sur le serveur et remplir. NE JAMAIS committer le .env rempli.

# ── Instagram (Graph API « Instagram login », graph.instagram.com) ──
# Compte Instagram PRO (Business/Créateur). PAS de Page Facebook requise par ce chemin.
# Permissions à valider en App Review : instagram_business_basic, instagram_business_content_publish.
IG_GRAPH_VERSION=v23.0
IG_USER_ID=                 # id du compte pro (renvoyé par /me à l'auth) — à reconfirmer dashboard
IG_ACCESS_TOKEN=           # token utilisateur Instagram LONG-LIVED (60 j) — tourne ensuite tout seul
# URL publique servant les images générées (cf. bloc Caddy du runbook). Sans slash final.
# L'image du jour devient : ${PUBLIC_BASE_URL}/<date>/ciel-day-<date>.jpg
PUBLIC_BASE_URL=https://llmastro.com/social

# ── Pinterest (API v5, api.pinterest.com/v5) ──
# Compte Business. Scope requis : pins:write (+ boards:read). Pas d'URL publique (envoi base64).
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=
PINTEREST_REFRESH_TOKEN=
PINTEREST_BOARD_ID=        # id du tableau « Ciel du jour » — à reconfirmer dashboard

# ── X / Twitter (API v2, texte + lien — palier GRATUIT, pas d'image) ──
# Portail developer.x.com → app avec permissions « Read and Write » (régénérer le token
# d'accès APRÈS avoir mis Read+Write, sinon il reste en lecture seule). 4 clés, pas d'OAuth.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── Lien de destination commun ──
POST_LINK=https://llmastro.com/ciel

# ── Alerte e-mail en cas d'échec (réutilise Resend, domaine llmastro.com déjà vérifié) ──
RESEND_API_KEY=
ALERT_FROM=Llmastro <info@llmastro.com>
ALERT_EMAIL=adrian.sauzade@gmail.com
