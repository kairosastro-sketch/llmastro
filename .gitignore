# ============================================================
# ASTRO PLATFORM — .gitignore
# GITIGNORE-CLEANUP-V1 applied
# ============================================================

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
.next/
out/
*.tsbuildinfo

# Environment — JAMAIS commit les secrets
.env
.env.local
.env.*.local
.env.production
.env.development
!.env.example

# Turbo / build cache
.turbo/
.cache/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Test coverage
coverage/
.nyc_output/

# Docker volumes (local dev)
docker/postgres/data/
docker/neo4j/data/
docker/redis/data/

# Swiss Ephemeris data files (volumineux, install via paquet)
*.se1
ephe/

# ============================================================
# Patches / archives Astro Platform — JAMAIS commit
# ============================================================

# Backups générés par les scripts apply.sh (legacy, format .backup-*)
.backup-*/

# Backups runtime des archives versionnées (format .archive-*-backup)
.archive-*-backup/

# Markers de patches déployés
.PATCH-*-APPLIED
.HOTFIX-*-APPLIED
.ARCHIVE-*-APPLIED

# Tarballs de patches (ne pas tracker)
*.tar.gz
*.tar.bz2
*.zip

# Backups historiques par fichier (artefacts d'éditeur ou anciens scripts)
*.bak-*
*.bak-[0-9]*
.bak-*

# Anciens scripts obsolètes (résidus historiques sur disque)
fix-ai-route.sh
.stabilize-sha

# Dossiers de salvage / cleanup historiques (résidus sur disque)
_salvage/
cleanup-salvage/

# Fichiers résiduels de scp Windows (brace expansion non évaluée — dossiers présents dans apps/web/)
{auth,natal,ui,charts}
{login,register}
{auth,api,utils}

# Caddy data (certificats Let's Encrypt — sensibles, persistent dans le volume Docker)
caddy_data/
caddy_config/
.github/workflows/

# Backups locaux (dumps SQL, copies de fichiers de config)
backups/

# Backups produits par les patches d'archives versionnées
*.swisseph-bak
*.npm-fix-bak
*.builder-fix-bak
*.pnpm-fix-bak
*.version-fix-bak
*.rebuild-fix-bak
*.distutils-fix-bak
*.cjs-fix-bak
*.dockerignore-bak

# Tarballs et dossiers d'archives extraites
ARCHIVE-*/
ARCHIVE-*.tar.gz

# Backups divers
.archive-backups/

# Backups DB locaux (jamais sur GitHub)
.dumps/
