# ============================================================
# ASTRO PLATFORM — Environment Variables
# ============================================================
# Copie ce fichier vers .env.local pour développement local
# JAMAIS commit .env.local ou .env avec de vraies valeurs
#
# Note CONFIG-HYGIENE-V1 : ce template ne liste QUE les variables
# réellement utilisées par le code applicatif. Toute variable
# ajoutée ici doit avoir au moins un usage process.env[...] côté
# code, ou un commentaire explicite "réservée pour archive future X".

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000

# ------------------------------------------------------------
# AUTH — JWT
# ------------------------------------------------------------
# Générer 64 chars random : openssl rand -base64 48
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_REFRESH_SECRET=another-64-char-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------------------
# AUTH — OAuth (Google) — optionnel pour dev, requis en prod si actif
# ------------------------------------------------------------
# 1. Console Google Cloud → API & Services → Credentials → OAuth 2.0 Client (Web)
# 2. Authorized redirect URIs : http://localhost:4000/auth/google/callback
#    (en prod : https://llmastro.com/api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ------------------------------------------------------------
# AUTH — OAuth (Facebook) — optionnel pour dev, requis en prod si actif
# ------------------------------------------------------------
# 1. Meta for Developers → My Apps → Create App → "Consumer" → Facebook Login
# 2. Settings → Valid OAuth Redirect URIs : http://localhost:4000/auth/facebook/callback
#    (en prod : https://llmastro.com/api/auth/facebook/callback)
# 3. App Review : la permission "email" est par défaut en Standard Access
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:4000/auth/facebook/callback

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
BACKEND_CORS_ORIGIN=http://localhost:3000

# ------------------------------------------------------------
# DATABASE — PostgreSQL (users, sessions, tiers, ai_readings)
# ------------------------------------------------------------
DATABASE_URL=postgresql://astro:change-me-secret@localhost:5432/astro_platform

# ------------------------------------------------------------
# CACHE — Redis
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# SWISS EPHEMERIS
# ------------------------------------------------------------
SWISSEPH_PATH=/usr/local/share/swisseph
SWISSEPH_HOUSE_SYSTEM=P
# Sélection du moteur de calcul des éphémérides :
#   - swisseph : Swiss Ephemeris en mode Moshier (précis, défaut)
#   - astracore : moteur maison (fallback de secours)
ASTRO_ENGINE=swisseph

# ------------------------------------------------------------
# IA — xAI (Grok via Kairos)
# ------------------------------------------------------------
# Clé API : https://x.ai (compte payant)
XAI_API_KEY=
XAI_MODEL=grok-4.3
XAI_BASE_URL=https://api.x.ai/v1
XAI_TIMEOUT_MS=45000
# Nombre max de tentatives sur erreur transitoire (5xx, réseau, réponse tronquée)
XAI_MAX_ATTEMPTS=3

# ------------------------------------------------------------
# Plans / Entitlements
# ------------------------------------------------------------
DEV_PLAN_SWITCH=true
ENTITLEMENTS_ENFORCED=false

# ------------------------------------------------------------
# COMMUNITY-V1 — stats sociales anonymes
# ------------------------------------------------------------
# Seuil de k-anonymité : un agrégat n'est exposé que s'il regroupe au moins
# COMMUNITY_K_MIN membres. Défaut 20 si non défini.
COMMUNITY_K_MIN=20

# ------------------------------------------------------------
# STRIPE-MVP-V1 — Paiement abonnements (Stripe Checkout + Portal)
# ------------------------------------------------------------
# Dashboard Stripe → Developers → API keys.
#   - STRIPE_SECRET_KEY      : sk_test_…  (live = sk_live_…)
#   - STRIPE_WEBHOOK_SECRET  : whsec_…  (Dashboard → Webhooks → Add endpoint
#                              OU `stripe listen --forward-to localhost:4000/subscriptions/webhook`)
#   - STRIPE_PRICE_ESSENTIAL_MONTHLY : price_…  (Products → Essentiel → mensuel 9,90€)
#   - STRIPE_PRICE_ESSENTIAL_YEARLY  : price_…  (Products → Essentiel → annuel 99€)  [PRICING-ANNUAL-V1]
#
# Si STRIPE_SECRET_KEY est vide, l'API tourne en mode "Stripe désactivé" :
# - GET /subscriptions/plans continue à fonctionner
# - POST /subscriptions/checkout et /portal renvoient 503 STRIPE_NOT_CONFIGURED
# - Le webhook répond 503 (Stripe re-postera quand activé)
# Si STRIPE_PRICE_ESSENTIAL_MONTHLY est vide, le checkout mensuel renvoie 503
# STRIPE_PRICE_MISSING — le front affiche un message d'indisponibilité.
# Idem pour STRIPE_PRICE_ESSENTIAL_YEARLY côté offre annuelle (toggle "Annuel"
# affiché mais "Bientôt disponible" tant que la variable est vide).
#
# Étapes de mise en route (voir STRIPE_SETUP.md pour le détail) :
#   1. Crée le produit "Essentiel" + prix mensuel 9,90€ sur Stripe (test mode)
#   2. Renseigne les trois variables ci-dessous
#   3. Reboot l'API → le seeder écrit stripe_price_id dans la table plans
#   4. En local : `stripe listen --forward-to http://localhost:4000/subscriptions/webhook`
#      et colle le whsec affiché dans STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENTIAL_MONTHLY=
STRIPE_PRICE_ESSENTIAL_YEARLY=
# Optionnel : épingler la version de l'API Stripe utilisée. Si vide, le SDK
# utilise sa version par défaut. À renseigner pour figer le schéma avant
# un upgrade majeur du SDK.
STRIPE_API_VERSION=

# ------------------------------------------------------------
# Admin (régénération de lectures persistées)
# ------------------------------------------------------------
# Générer un token random 32 chars : openssl rand -hex 16
ADMIN_API_TOKEN=

# ------------------------------------------------------------
# Revalidation ISR des pages /ciel (CIEL-ISR-REVALIDATE-V1)
# ------------------------------------------------------------
# Secret partagé api ↔ web. Le backend (boot/init-sky) POST vers
# WEB_REVALIDATE_URL avec ce secret dès qu'une publication change
# de période ou que son texte Kairos est généré ; le web invalide
# alors le cache de la cadence concernée (revalidateTag).
# Laisser vide désactive la feature (fallback : revalidate temporel).
# Générer : openssl rand -hex 32
REVALIDATE_SECRET=
# URL interne de l'endpoint de revalidation côté web (consommée par l'API).
# En prod Docker : http://web:3000/revalidate-sky
WEB_REVALIDATE_URL=http://localhost:3000/revalidate-sky

# ------------------------------------------------------------
# Frontend Next.js — variables PUBLIQUES
# ------------------------------------------------------------
# IMPORTANT : NEXT_PUBLIC_* sont inlinées au build time.
# La valeur dans le Dockerfile (web.Dockerfile) prime sur celle-ci.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ------------------------------------------------------------
# WEB-PUSH-V1 — Notifications navigateur (Web Push API)
# ------------------------------------------------------------
# Génération des clés VAPID (à exécuter une seule fois, dev & prod) :
#   npx web-push generate-vapid-keys
# Copier `Public Key` dans VAPID_PUBLIC_KEY + NEXT_PUBLIC_VAPID_PUBLIC_KEY
# (les deux DOIVENT être identiques — le navigateur lit la version publique
# au build, l'API lit la même valeur pour signer les sends). Copier
# `Private Key` dans VAPID_PRIVATE_KEY (côté API uniquement, JAMAIS NEXT_PUBLIC).
# VAPID_SUBJECT est un mailto: ou https:// stable identifiant le sender —
# requis par le RFC 8292 (pas un secret, mais doit être joignable).
# Si l'une des trois variables côté API est vide, le push dispatch devient
# un no-op silencieux (les notifs in-app continuent normalement).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ------------------------------------------------------------
# EMAIL — ARCHIVE-AUTH-EMAIL-VERIFY-V1
# ------------------------------------------------------------
# Provider transactionnel : Resend (https://resend.com).
# Le DNS du domaine (SPF / DKIM / DMARC) doit être configuré
# côté registrar pour que les envois ne tombent pas en spam ;
# l'adresse `EMAIL_FROM` doit pointer sur un sender vérifié
# côté Resend, sinon l'API renvoie 422 à l'envoi.
#
# Comportement si vide : le service `mailer.ts` est no-op
# silencieux (l'API démarre, les signups passent, mais l'email
# de vérif n'est pas envoyé). Pratique en dev local.
RESEND_API_KEY=
EMAIL_FROM=noreply@llmastro.com

# ------------------------------------------------------------
# OBSERVABILITY
# ------------------------------------------------------------
LOG_LEVEL=debug

# ------------------------------------------------------------
# DOCKER COMPOSE
# ------------------------------------------------------------
POSTGRES_PASSWORD=change-me-secret

# ARCHIVE-EPHEMERIDES-SWISSEPH-V1 applied
# CONFIG-HYGIENE-V1 applied
