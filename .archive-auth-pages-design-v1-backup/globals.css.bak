@tailwind base;
@tailwind components;
@tailwind utilities;

/* ============================================================
   ASTRO PLATFORM — Design System v4 · AstraCore
   Polices 100% système · Light + Dark · Mobile-first
   ============================================================ */

/* ──────────────────────────────────────────────────────────
   TOKENS — DARK MODE (défaut)
   ────────────────────────────────────────────────────────── */
:root,
[data-theme="dark"] {
  color-scheme: dark;

  --bg:         #07050f;
  --bg-2:       #0d0a1a;
  --bg-3:       #141027;
  --bg-raised:  rgba(255,255,255,.025);
  --bg-pressed: rgba(255,255,255,.045);

  --gold:       #c9a84c;
  --gold-l:     #e8c97a;
  --gold-d:     #8a6e2e;
  --star:       #f0e6c8;      /* texte primaire dark */
  --muted:      rgba(240,230,200,.50);
  --muted-2:    rgba(240,230,200,.30);

  --indigo:     #1b1464;
  --purple:     #2d1b69;

  --harmony:    #3ecf8e;
  --tension:    #e54545;
  --neutral:    #d4a017;
  --info:       #5b8af0;

  --border:      rgba(201,168,76,.15);
  --border-soft: rgba(201,168,76,.08);
  --border-mid:  rgba(201,168,76,.28);

  --surface-alt: rgba(255,255,255,.04);
  --card-bg:     rgba(255,255,255,.025);
  --card-border: rgba(201,168,76,.08);
  --input-bg:    rgba(255,255,255,.04);
  --chip-bg:     rgba(255,255,255,.04);

  --shadow-soft:  0 2px 20px rgba(0,0,0,.45);
  --shadow-gold:  0 0 18px rgba(201,168,76,.22);
  --shadow-float: 0 8px 36px rgba(0,0,0,.55);

  --stars-color:  #f0e6c8;
}

/* ──────────────────────────────────────────────────────────
   TOKENS — LIGHT MODE
   ────────────────────────────────────────────────────────── */
[data-theme="light"] {
  color-scheme: light;

  --bg:         #faf7f0;       /* parchemin */
  --bg-2:       #f2ecdd;
  --bg-3:       #e8e0c8;
  --bg-raised:  rgba(0,0,0,.025);
  --bg-pressed: rgba(0,0,0,.045);

  --gold:       #8a5e10;       /* or sombre pour contraste */
  --gold-l:     #6b4a0d;       /* encore plus sombre pour accents */
  --gold-d:     #c9a84c;
  --star:       #1a1230;       /* texte primaire light = nuit profonde */
  --muted:      rgba(26,18,48,.55);
  --muted-2:    rgba(26,18,48,.35);

  --indigo:     #4338ca;
  --purple:     #6d28d9;

  --harmony:    #0d9058;
  --tension:    #c42b2b;
  --neutral:    #9c6d00;
  --info:       #2b5fc9;

  --border:      rgba(138,94,16,.22);
  --border-soft: rgba(138,94,16,.10);
  --border-mid:  rgba(138,94,16,.35);

  --surface-alt: rgba(0,0,0,.04);
  --card-bg:     rgba(255,255,255,.72);
  --card-border: rgba(138,94,16,.14);
  --input-bg:    rgba(255,255,255,.82);
  --chip-bg:     rgba(255,255,255,.72);

  --shadow-soft:  0 2px 16px rgba(0,0,0,.08);
  --shadow-gold:  0 0 18px rgba(138,94,16,.14);
  --shadow-float: 0 8px 28px rgba(0,0,0,.12);

  --stars-color:  #8a5e10;
}

/* ──────────────────────────────────────────────────────────
   POLICES — 100% système, aucun chargement réseau
   ────────────────────────────────────────────────────────── */
:root {
  --font-body:
    "Trebuchet MS", "Lucida Sans Unicode", "Lucida Grande",
    -apple-system, BlinkMacSystemFont, "Segoe UI",
    Roboto, "Helvetica Neue", Arial, sans-serif;

  --font-display:
    Georgia, "Palatino Linotype", Palatino, "URW Palladio L",
    "Book Antiqua", Baskerville, serif;

  --font-mono:
    ui-monospace, SFMono-Regular, Menlo, Monaco,
    Consolas, "Liberation Mono", "Courier New", monospace;

  --safe-top:    env(safe-area-inset-top, 0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);

  --ease-out:    cubic-bezier(.16,1,.3,1);
  --ease-spring: cubic-bezier(.22,1,.36,1);

  --r-sm: 8px;
  --r-md: 11px;
  --r-lg: 14px;
  --r-xl: 20px;
}

/* ──────────────────────────────────────────────────────────
   RESET
   ────────────────────────────────────────────────────────── */
@layer base {
  *, *::before, *::after {
    margin: 0; padding: 0;
    box-sizing: border-box;
  }

  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    font-size: 15px;
  }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--star);                /* ← toute l'app hérite de cette couleur */
    min-height: 100dvh;
    transition: background .3s var(--ease-out), color .3s var(--ease-out);
  }

  /* Assure que TOUT hérite correctement — fix critique mode sombre/clair */
  h1, h2, h3, h4, h5, h6,
  p, span, div, li, td, th,
  label, caption, figcaption,
  blockquote, cite {
    color: inherit;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: .5px;
  }

  a {
    color: var(--gold);
    text-decoration: none;
    transition: opacity .18s;
  }
  a:hover { opacity: .75; }

  button {
    font-family: inherit;
    cursor: pointer;
    border: none;
    background: none;
    color: inherit;
  }
  button:disabled { cursor: not-allowed; opacity: .42; }

  /* Inputs avec fond selon thème — fix mode clair */
  input, textarea, select {
    font-family: inherit;
    font-size: 15px;
    color: var(--star) !important;
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 12px 14px;
    outline: none;
    transition: border-color .25s, box-shadow .25s;
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
  }

  input::placeholder, textarea::placeholder {
    color: var(--muted-2);
  }

  /* AUTH-UX-POLISH-V1-FIXES : checkbox/radio ne doivent PAS hériter du width:100%
     de la règle générique input/textarea/select ci-dessus. Sans cette override,
     elles s'affichent étirées sur toute la largeur du formulaire. */
  input[type="checkbox"],
  input[type="radio"] {
    width: 16px;
    height: 16px;
    padding: 0;
    accent-color: var(--gold);
    cursor: pointer;
    flex-shrink: 0;
  }

  input:focus, textarea:focus, select:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201,168,76,.15);
  }

  /* Fix Safari autofill dark */
  input:-webkit-autofill {
    -webkit-text-fill-color: var(--star) !important;
    -webkit-box-shadow: 0 0 0 1000px var(--input-bg) inset !important;
    transition: background-color 9999s ease-out 0s;
  }

  select option {
    background: var(--bg-2);
    color: var(--star);
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb {
    background: var(--border-mid);
    border-radius: 4px;
  }
}

/* ──────────────────────────────────────────────────────────
   STARS BACKGROUND — animation légère
   ────────────────────────────────────────────────────────── */
.stars-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}
.stars-bg .star {
  position: absolute;
  width: 2px; height: 2px;
  background: var(--stars-color);
  border-radius: 50%;
  animation: twinkle var(--d, 3s) ease-in-out infinite alternate;
  will-change: opacity, transform;
}
@keyframes twinkle {
  0%   { opacity: .12; transform: scale(.6); }
  100% { opacity: var(--o, .9); transform: scale(1.2); }
}

/* ──────────────────────────────────────────────────────────
   APP SHELL
   ────────────────────────────────────────────────────────── */
.app-shell {
  position: relative;
  z-index: 1;
  display: flex;
  min-height: 100dvh;
}

/* Sidebar desktop */
.sidebar {
  width: 216px;
  min-width: 216px;
  background: var(--bg);
  border-right: 1px solid var(--border-soft);
  height: 100dvh;
  position: sticky;
  top: 0;
  display: flex;
  flex-direction: column;
  z-index: 40;
}

@media (max-width: 768px) {
  .sidebar { display: none; }
}

/* Main zone */
.main-zone {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  min-height: 100dvh;
}

/* Topbar mobile */
.topbar {
  display: none;
  height: 56px;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  padding-top: var(--safe-top);
  border-bottom: 1px solid var(--border-soft);
  background: var(--bg);
  position: sticky;
  top: 0;
  z-index: 30;
  backdrop-filter: saturate(150%);
}
@media (max-width: 768px) {
  .topbar { display: flex; }
}

.tb-logo {
  font-family: var(--font-display);
  font-size: 19px;
  color: var(--gold);
  letter-spacing: 1px;
  cursor: pointer;
  display: flex; align-items: center; gap: 5px;
}

.tb-right {
  display: flex; align-items: center; gap: 10px;
}

/* Content */
.content-area {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
}

.page-root {
  max-width: 720px;
  margin: 0 auto;
  padding: 16px 16px calc(80px + var(--safe-bottom));
}

@media (min-width: 768px) {
  .page-root {
    padding: 28px 24px 32px;
  }
}

/* ──────────────────────────────────────────────────────────
   NAVIGATION — sidebar desktop
   ────────────────────────────────────────────────────────── */
.sidebar-brand {
  padding: 18px 14px 16px;
  border-bottom: 1px solid var(--border-soft);
}
.sidebar-brand-row {
  display: flex; align-items: center; gap: 10px;
}
.sidebar-brand-logo {
  width: 32px; height: 32px;
  border-radius: var(--r-md);
  background: rgba(201,168,76,.1);
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  color: var(--gold); font-size: 16px; flex-shrink: 0;
}
.sidebar-brand-name {
  font-family: var(--font-display);
  font-size: 16px;
  color: var(--star);
  letter-spacing: 1.5px;
}

.sidebar-nav {
  flex: 1; padding: 8px 0; overflow-y: auto;
}

.sidebar-link {
  display: flex; align-items: center;
  gap: 11px;
  padding: 9px 14px;
  margin: 2px 8px;
  border-radius: var(--r-md);
  font-size: 13px;
  color: var(--muted);
  border: 1px solid transparent;
  transition: all .18s var(--ease-out);
  text-decoration: none;
}
.sidebar-link:hover {
  background: var(--bg-raised);
  color: var(--star);
}
.sidebar-link.active {
  background: rgba(201,168,76,.08);
  color: var(--gold);
  border-color: var(--border);
}
[data-theme="light"] .sidebar-link.active {
  background: rgba(138,94,16,.08);
}
.sidebar-link .icon {
  font-size: 16px;
  width: 20px;
  text-align: center;
  flex-shrink: 0;
}

/* Sidebar footer */
.sidebar-footer {
  padding: 10px;
  border-top: 1px solid var(--border-soft);
}

/* ──────────────────────────────────────────────────────────
   BOTTOM NAV — mobile
   ────────────────────────────────────────────────────────── */
.bottom-nav {
  display: none;
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: calc(60px + var(--safe-bottom));
  padding-bottom: var(--safe-bottom);
  background: var(--bg);
  border-top: 1px solid var(--border-soft);
  z-index: 50;
  backdrop-filter: saturate(150%);
}
@media (max-width: 768px) {
  .bottom-nav { display: flex; }
}

.bn-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  font-size: 9px;
  letter-spacing: .5px;
  text-transform: uppercase;
  color: var(--muted);
  transition: color .22s;
  position: relative;
  text-decoration: none;
  padding: 4px;
  -webkit-tap-highlight-color: transparent;
}
.bn-item .ico { font-size: 19px; transition: transform .22s; line-height: 1; }
.bn-item.active { color: var(--gold); }
.bn-item.active .ico { transform: scale(1.12); }
.bn-item.active::after {
  content: '';
  position: absolute; top: 0;
  left: 18%; right: 18%;
  height: 2.5px;
  background: var(--gold);
  border-radius: 0 0 3px 3px;
}

/* Subnav (onglets horaires horoscope) */
.subnav {
  display: flex;
  justify-content: center;
  gap: 20px;
  padding: 10px 0;
  border-bottom: 1px solid var(--border-soft);
  margin-bottom: 14px;
}
.subnav-tab {
  font-size: 12px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--muted);
  padding: 4px 0;
  border-bottom: 2px solid transparent;
  transition: all .22s;
  cursor: pointer;
  background: none;
  border-left: none;
  border-right: none;
  border-top: none;
}
.subnav-tab.active {
  color: var(--gold);
  border-bottom-color: var(--gold);
}

/* ──────────────────────────────────────────────────────────
   COMPOSANTS TEMPLATE
   ────────────────────────────────────────────────────────── */

/* Section title + separator */
.section-title {
  font-family: var(--font-display);
  font-size: 16px;
  color: var(--gold);
  letter-spacing: .5px;
  margin-bottom: 10px;
}

.section-sub {
  font-size: 10px;
  color: var(--muted);
  font-style: italic;
  margin: -6px 0 10px;
  letter-spacing: .3px;
}

.sep {
  height: 1px;
  margin: 20px 0;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  opacity: .5;
}

/* Card */
.card {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: var(--r-lg);
  padding: 14px;
  transition: transform .22s var(--ease-out), border-color .22s;
}
.card:hover {
  border-color: var(--border-mid);
}

.card-gold {
  background: rgba(201,168,76,.06);
  border: 1px solid var(--border);
}
[data-theme="light"] .card-gold {
  background: rgba(138,94,16,.06);
}

/* Pill / badge */
.pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 3px 11px;
  border-radius: 13px;
  font-size: 11px;
  letter-spacing: .5px;
}
.pill-h { background: rgba(62,207,142,.14);  color: var(--harmony); }
.pill-t { background: rgba(229,69,69,.14);   color: var(--tension); }
.pill-n { background: rgba(212,160,23,.14);  color: var(--neutral); }
.pill-info { background: rgba(91,138,240,.14); color: var(--info); }

.pill-gold {
  background: rgba(201,168,76,.10);
  border: 1px solid var(--border);
  color: var(--gold-l);
  padding: 4px 13px;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1px;
}
[data-theme="light"] .pill-gold { color: var(--gold); }

.pill-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--harmony);
  animation: pulse 1.8s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: .4; transform: scale(.85); }
  50%      { opacity: 1;  transform: scale(1.15); }
}

/* Live indicator */
.live {
  display: inline-flex;
  align-items: center; gap: 5px;
  padding: 2px 9px;
  border-radius: 8px;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--harmony);
  background: rgba(62,207,142,.10);
}
.live::before {
  content: '';
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--harmony);
  animation: pulse 1.8s infinite;
}

/* Energy bar */
.ebar { margin-bottom: 11px; }
.ebar-head {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  margin-bottom: 5px;
}
.ebar-head .lbl {
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .8px;
  font-size: 10px;
}
.ebar-head .val {
  color: var(--gold);
  font-family: var(--font-display);
  font-size: 13px;
}
.ebar-track {
  height: 6px;
  background: var(--surface-alt);
  border-radius: 3px;
  overflow: hidden;
}
.ebar-fill {
  height: 100%;
  border-radius: 3px;
  background: linear-gradient(90deg, var(--gold), var(--gold-l));
  transition: width 1.2s var(--ease-spring);
}

/* Grid 2 cols for domains */
.grid2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.grid2 .card { text-align: center; }
.grid2 .card .ico {
  font-size: 20px;
  display: block;
  margin-bottom: 4px;
}
.grid2 .card .val {
  font-family: var(--font-display);
  font-size: 22px;
  color: var(--gold);
  margin-bottom: 3px;
}
.grid2 .card .lbl {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .8px;
  margin-bottom: 4px;
}
.grid2 .card .msg {
  font-family: var(--font-display);
  font-size: 11.5px;
  color: var(--star);
  opacity: .75;
  line-height: 1.35;
}

/* Oracle quote */
.oracle {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 13.5px;
  line-height: 1.65;
  color: var(--star);
  opacity: .82;
  text-align: center;
  padding: 14px 12px;
  border-left: 2px solid var(--gold);
  margin: 14px 0;
}

/* Alert banner */
.alert-banner {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 11px 13px;
  margin-bottom: 10px;
  border-radius: var(--r-md);
  background: rgba(212,160,23,.06);
  border: 1px solid rgba(212,160,23,.22);
  font-size: 12.5px;
  line-height: 1.5;
  color: var(--neutral);
}
.alert-banner .ab-ico {
  font-size: 15px;
  flex-shrink: 0;
  margin-top: 1px;
}

/* Moon phase box */
.moon-phase {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 13px;
  border-radius: var(--r-lg);
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  margin-bottom: 12px;
}
.moon-phase .ico   { font-size: 34px; line-height: 1; }
.moon-phase .name  { font-family: var(--font-display); font-size: 15px; color: var(--gold); margin-bottom: 3px; }
.moon-phase .desc  { font-size: 12px; color: var(--muted); line-height: 1.45; }

/* Hero section with orbits */
.hero {
  text-align: center;
  padding: 14px 0 10px;
}
.wheel-wrap {
  width: 170px;
  height: 170px;
  margin: 0 auto 14px;
  position: relative;
}
.wheel-orbit {
  position: absolute;
  border: 1px solid var(--border);
  border-radius: 50%;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
}
.wo1 { width: 155px; height: 155px; animation: spin-orbit 40s linear infinite; }
.wo2 { width: 110px; height: 110px; animation: spin-orbit 28s linear infinite reverse; }
.wo3 { width: 68px;  height: 68px;  animation: spin-orbit 18s linear infinite; }
@keyframes spin-orbit { to { transform: translate(-50%, -50%) rotate(360deg); } }

.wheel-orbit::after {
  content: '';
  position: absolute;
  width: 7px; height: 7px;
  background: var(--gold-l);
  border-radius: 50%;
  top: -3px; left: 50%;
  margin-left: -3px;
  box-shadow: 0 0 7px rgba(201,168,76,.5);
}
.wo2::after { width: 5px; height: 5px; top: auto; bottom: -2px; margin-left: -2px; background: var(--star); }
.wo3::after { width: 4px; height: 4px; left: auto; right: -2px; top: 50%; margin-top: -2px; background: var(--gold); }

.wheel-sun {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 22px; height: 22px;
  border-radius: 50%;
  background: radial-gradient(circle, var(--gold-l), var(--gold), rgba(201,168,76,.2));
  box-shadow: 0 0 16px rgba(201,168,76,.45);
}

.hero-sign { font-size: 30px; line-height: 1; margin-bottom: 4px; }
.hero-name { font-family: var(--font-display); font-size: 19px; color: var(--gold); }
.hero-info { font-size: 11px; color: var(--muted); margin-top: 4px; letter-spacing: .3px; }

/* Header horoscope */
.horo-header {
  text-align: center;
  padding: 8px 0 16px;
}
.horo-circle {
  width: 54px; height: 54px;
  border-radius: 50%;
  border: 2px solid var(--gold);
  display: flex; align-items: center; justify-content: center;
  font-size: 25px;
  margin: 0 auto 7px;
  color: var(--gold);
}
.horo-sname { font-family: var(--font-display); font-size: 18px; color: var(--gold); }
.horo-meta  { font-size: 11px; color: var(--muted); margin-top: 3px; letter-spacing: .3px; }

/* Week band */
.week-band {
  display: flex;
  gap: 7px;
  overflow-x: auto;
  padding: 6px 0 12px;
  -webkit-overflow-scrolling: touch;
}
.week-band::-webkit-scrollbar { display: none; }

.wday {
  flex-shrink: 0;
  width: 48px;
  text-align: center;
  padding: 7px 0;
  border-radius: var(--r-md);
  border: 1.5px solid var(--border-soft);
  color: var(--star);
}
.wday.today {
  border-color: var(--gold);
  background: rgba(201,168,76,.06);
}
.wday .wd-name { font-size: 9px; text-transform: uppercase; color: var(--muted); letter-spacing: .5px; }
.wday .wd-num  { font-family: var(--font-display); font-size: 16px; color: var(--star); margin: 3px 0; }
.wday .wd-mood { font-size: 14px; }

/* Calendar month */
.mcal-title {
  text-align: center;
  font-family: var(--font-display);
  font-size: 14px;
  color: var(--gold);
  margin-bottom: 8px;
  letter-spacing: .5px;
  text-transform: capitalize;
}
.mcal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 2px;
  text-align: center;
}
.mcal-hd {
  font-size: 9px;
  color: var(--muted);
  text-transform: uppercase;
  padding: 4px 0;
  letter-spacing: .3px;
}
.mcal-d {
  font-size: 11.5px;
  padding: 5px 0;
  border-radius: var(--r-sm);
  position: relative;
  color: var(--muted);
  transition: background .18s;
}
.mcal-d.cur {
  color: var(--gold);
  background: rgba(201,168,76,.12);
  font-weight: 600;
}
.mcal-d.evt::after {
  content: '';
  position: absolute;
  bottom: 1px; left: 50%;
  transform: translateX(-50%);
  width: 3px; height: 3px;
  border-radius: 50%;
  background: var(--gold);
}
.mcal-d.empty { visibility: hidden; }

/* Aspect list */
.aspect-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 6px;
}

/* Predictions text */
.pred-text {
  font-family: var(--font-display);
  font-size: 12.5px;
  line-height: 1.7;
  color: var(--star);
  opacity: .8;
  margin-top: 10px;
}
.pred-text p { margin-bottom: 9px; }

/* Planet table */
.planet-table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 8px;
}
.planet-table th {
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: .8px;
  color: var(--muted);
  text-align: left;
  padding: 6px 4px;
  border-bottom: 1px solid var(--border-soft);
}
.planet-table td {
  font-size: 12.5px;
  padding: 7px 4px;
  border-bottom: 1px solid var(--border-soft);
  color: var(--star);
}
.planet-table td:first-child {
  font-size: 17px;
  width: 26px;
  color: var(--gold);
}

/* Elements grid */
.elem-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin-top: 8px;
}
.elem-col { text-align: center; }
.elem-col .e-ico {
  font-size: 17px;
  margin-bottom: 4px;
}
.elem-col .e-lbl {
  font-size: 9px;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 6px;
  letter-spacing: .3px;
}
.elem-col .e-bar-wrap {
  height: 54px;
  width: 18px;
  margin: 0 auto;
  background: var(--surface-alt);
  border-radius: var(--r-sm);
  position: relative;
  overflow: hidden;
}
.elem-col .e-bar {
  position: absolute;
  bottom: 0;
  width: 100%;
  border-radius: var(--r-sm);
  transition: height 1.2s var(--ease-spring);
}
.elem-col .e-val {
  font-family: var(--font-display);
  font-size: 13px;
  color: var(--gold);
  margin-top: 4px;
}

/* Houses grid */
.houses-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
  margin-top: 8px;
}
.house-card {
  text-align: center;
  padding: 9px 4px;
  background: var(--surface-alt);
  border: 1px solid var(--border-soft);
  border-radius: var(--r-md);
}
.house-card .h-num  { font-family: var(--font-display); font-size: 15px; color: var(--gold); }
.house-card .h-ico  { font-size: 13px; margin: 2px 0; }
.house-card .h-name { font-size: 8.5px; color: var(--muted); text-transform: uppercase; letter-spacing: .3px; }

/* Numerology box */
.numero-box {
  text-align: center;
  padding: 20px;
  border-radius: var(--r-lg);
  background: rgba(201,168,76,.05);
  border: 1px solid var(--border);
}
[data-theme="light"] .numero-box {
  background: rgba(138,94,16,.06);
}
.numero-num {
  font-family: var(--font-display);
  font-size: 48px;
  color: var(--gold);
  line-height: 1;
}
.numero-label {
  font-size: 11px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin: 8px 0 10px;
}
.numero-desc {
  font-family: var(--font-display);
  font-size: 12.5px;
  line-height: 1.65;
  color: var(--star);
  opacity: .82;
}

/* Compat */
.compat-result {
  text-align: center;
  margin-top: 16px;
  animation: fade-up .4s ease;
}
.compat-score {
  font-family: var(--font-display);
  font-size: 50px;
  color: var(--gold);
  line-height: 1;
}
.compat-message {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 12.5px;
  color: var(--star);
  opacity: .75;
  margin-top: 8px;
}
.compat-bar {
  height: 7px;
  background: var(--surface-alt);
  border-radius: 4px;
  overflow: hidden;
  margin: 12px 0;
}
.compat-bar-fill {
  height: 100%;
  border-radius: 4px;
  background: linear-gradient(90deg, var(--tension), var(--neutral), var(--harmony));
  transition: width 1s ease;
}
.compat-details {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 10px;
}

/* Tarot */
.tarot-deck {
  display: flex;
  justify-content: center;
  gap: 11px;
  margin: 16px 0;
  min-height: 160px;
  align-items: center;
}
.tarot-card {
  width: 95px;
  height: 148px;
  border-radius: var(--r-md);
  border: 1.5px solid var(--border);
  background: rgba(201,168,76,.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all .4s var(--ease-out);
  overflow: hidden;
  position: relative;
}
.tarot-card.face-down {
  background: linear-gradient(135deg, var(--indigo), var(--purple));
  border-color: var(--border);
}
.tarot-card.face-down::after {
  content: '✦';
  font-size: 24px;
  color: var(--gold);
  opacity: .55;
}
.tarot-card.revealed {
  border-color: var(--gold);
  background: rgba(201,168,76,.06);
  cursor: default;
  animation: reveal-card .55s var(--ease-spring);
}
@keyframes reveal-card {
  from { transform: rotateY(90deg); opacity: .2; }
  to   { transform: rotateY(0);     opacity: 1; }
}
.tarot-card .tc-num  { font-size: 26px; margin-bottom: 4px; }
.tarot-card .tc-name {
  font-family: var(--font-display);
  font-size: 10px;
  color: var(--gold);
  text-align: center;
  padding: 0 5px;
  line-height: 1.3;
}
.tarot-card .tc-pos {
  position: absolute;
  top: 5px; left: 0; right: 0;
  font-size: 8px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--muted);
  text-align: center;
}
.tarot-interp {
  font-family: var(--font-display);
  font-size: 12.5px;
  line-height: 1.65;
  color: var(--star);
  opacity: .85;
  margin-top: 14px;
  padding: 13px;
  border-radius: var(--r-lg);
  background: var(--card-bg);
  border: 1px solid var(--card-border);
}
.tarot-interp p { margin-bottom: 7px; }

/* Chat */
.chat-intro {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 12.5px;
  color: var(--muted);
  text-align: center;
  margin-bottom: 10px;
  line-height: 1.5;
}
.planet-sel {
  display: flex;
  gap: 6px;
  overflow-x: auto;
  padding: 4px 0 10px;
  -webkit-overflow-scrolling: touch;
}
.planet-sel::-webkit-scrollbar { display: none; }
.psel {
  flex-shrink: 0;
  padding: 6px 12px;
  border-radius: 18px;
  border: 1.5px solid var(--border-soft);
  font-size: 11.5px;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 5px;
  cursor: pointer;
  transition: all .22s;
  background: transparent;
}
.psel.active {
  border-color: var(--gold);
  color: var(--gold);
  background: rgba(201,168,76,.05);
}

.chat-msgs {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 9px;
  padding-bottom: 8px;
}
.chat-msg {
  max-width: 84%;
  padding: 10px 13px;
  font-family: var(--font-display);
  font-size: 13.5px;
  line-height: 1.55;
  animation: fade-up .3s ease;
}
.chat-msg.planet {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 0 13px 13px 13px;
  align-self: flex-start;
}
.chat-msg.user {
  background: rgba(201,168,76,.10);
  border-radius: 13px 13px 0 13px;
  align-self: flex-end;
}
.chat-sender {
  font-size: 8px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--gold);
  margin-bottom: 4px;
  font-family: var(--font-body);
}
.chat-typing {
  display: flex;
  gap: 4px;
  padding: 10px 13px;
  align-self: flex-start;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 0 13px 13px 13px;
}
.chat-typing span {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--gold);
  animation: typing-dot 1.2s ease-in-out infinite;
}
.chat-typing span:nth-child(2) { animation-delay: .2s; }
.chat-typing span:nth-child(3) { animation-delay: .4s; }
@keyframes typing-dot {
  0%, 100% { opacity: .2; transform: scale(.7); }
  50%      { opacity: 1;  transform: scale(1); }
}

.chat-input-wrap {
  display: flex;
  gap: 8px;
  padding: 8px 0 4px;
  border-top: 1px solid var(--border-soft);
}
.chat-input {
  flex: 1;
  border-radius: 20px;
  padding: 10px 15px;
  font-size: 13px;
  font-family: inherit;
}
.chat-send {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: var(--gold);
  color: var(--bg);
  font-size: 17px;
  display: flex; align-items: center; justify-content: center;
  transition: transform .2s, filter .2s;
  flex-shrink: 0;
}
.chat-send:hover:not(:disabled) { filter: brightness(1.1); }
.chat-send:active:not(:disabled) { transform: scale(.92); }
.chat-send:disabled { opacity: .4; }

/* Glossary */
.glossary-tabs {
  display: flex;
  gap: 7px;
  overflow-x: auto;
  margin-bottom: 14px;
  padding-bottom: 2px;
}
.glossary-tabs::-webkit-scrollbar { display: none; }
.gtab {
  flex-shrink: 0;
  padding: 6px 14px;
  border-radius: 18px;
  border: 1px solid var(--border-soft);
  background: transparent;
  font-size: 11.5px;
  color: var(--muted);
  cursor: pointer;
  transition: all .22s;
}
.gtab.active {
  border-color: var(--gold);
  color: var(--gold);
  background: rgba(201,168,76,.07);
}
.glossary-item {
  padding: 11px 0;
  border-bottom: 1px solid var(--border-soft);
}
.glossary-item:last-child { border: none; }
.gi-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  width: 100%;
  background: transparent;
  text-align: left;
  padding: 0;
}
.gi-title {
  font-family: var(--font-display);
  font-size: 13.5px;
  color: var(--gold);
}
.gi-arrow {
  color: var(--muted);
  font-size: 11px;
  transition: transform .3s;
}
.gi-arrow.open { transform: rotate(90deg); }
.gi-body {
  font-size: 12.5px;
  line-height: 1.6;
  color: var(--star);
  opacity: .78;
  padding-top: 8px;
}

/* Explore subnav */
.explore-nav {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin: 0 -16px 16px;
  padding: 8px 16px;
  border-bottom: 1px solid var(--border-soft);
}

/* Avatar */
.avatar {
  width: 34px; height: 34px;
  border-radius: 50%;
  border: 1.5px solid var(--gold);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px;
  color: var(--gold);
  background: transparent;
  cursor: pointer;
  transition: box-shadow .25s;
}
.avatar:hover { box-shadow: 0 0 12px rgba(201,168,76,.35); }

/* Language/Theme toggle buttons */
.tb-toggle {
  font-size: 11px;
  color: var(--gold);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  padding: 4px 9px;
  letter-spacing: 1px;
  cursor: pointer;
  transition: background .2s;
  background: transparent;
  text-transform: uppercase;
}
.tb-toggle:hover { background: rgba(201,168,76,.08); }
[data-theme="light"] .tb-toggle:hover { background: rgba(138,94,16,.08); }

/* Buttons */
.btn-ob {
  width: 100%;
  background: linear-gradient(135deg, var(--gold), var(--gold-l));
  color: var(--bg);
  border: none;
  border-radius: var(--r-md);
  padding: 15px;
  font-size: 16px;
  font-family: var(--font-display);
  font-weight: 700;
  letter-spacing: 1.2px;
  cursor: pointer;
  transition: transform .2s, box-shadow .2s;
}
.btn-ob:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 6px 24px rgba(201,168,76,.3);
}
.btn-ob:active:not(:disabled) { transform: scale(.98); }

.btn-ghost {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  padding: 9px 18px;
  border-radius: var(--r-md);
  background: rgba(201,168,76,.08);
  border: 1px solid var(--border);
  color: var(--gold);
  font-family: var(--font-display);
  font-size: 13px;
  cursor: pointer;
  transition: all .22s;
}
.btn-ghost:hover:not(:disabled) { background: rgba(201,168,76,.14); }
[data-theme="light"] .btn-ghost { background: rgba(138,94,16,.08); }
[data-theme="light"] .btn-ghost:hover:not(:disabled) { background: rgba(138,94,16,.14); }

.btn-danger {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 7px 14px;
  border-radius: var(--r-md);
  background: rgba(229,69,69,.10);
  border: 1px solid rgba(229,69,69,.28);
  color: var(--tension);
  font-size: 12px;
  cursor: pointer;
}
.btn-danger:hover:not(:disabled) { background: rgba(229,69,69,.18); }

/* Label form */
.form-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  color: var(--muted);
  margin-bottom: 5px;
  display: block;
}

/* Spinner */
.spinner {
  width: 28px; height: 28px;
  border-radius: 50%;
  border: 2px solid var(--border);
  border-top-color: var(--gold);
  animation: spin .8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Onboarding / empty state */
.empty-state {
  padding: 40px 20px;
  text-align: center;
}
.empty-state .ico {
  font-size: 42px;
  color: var(--gold);
  opacity: .55;
  margin-bottom: 12px;
  display: inline-block;
  animation: float-y 3s ease-in-out infinite;
}
@keyframes float-y {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-8px); }
}
.empty-state .msg {
  font-family: var(--font-display);
  font-size: 14px;
  color: var(--muted);
  line-height: 1.55;
  max-width: 280px;
  margin: 0 auto;
}

/* ──────────────────────────────────────────────────────────
   ZODIAC WHEEL container
   ────────────────────────────────────────────────────────── */
.wheel-container {
  position: relative;
  width: 100%;
  max-width: 560px;
  margin: 0 auto;
  touch-action: none;
  user-select: none;
}

/* Chart natal SVG small */
.natal-svg-wrap {
  text-align: center;
  margin: 10px 0 14px;
}
/* ARCHIVE-NATAL-SVG-CENTER-FIX-V2 : Tailwind Preflight met les SVG en display:block,
   ce qui désactive text-align:center sur le parent. On force le centrage via margin auto. */
.natal-svg-wrap svg {
  filter: drop-shadow(0 0 12px rgba(201,168,76,.14));
  display: block;
  margin-left: auto;
  margin-right: auto;
}

/* ──────────────────────────────────────────────────────────
   UTILITIES
   ────────────────────────────────────────────────────────── */
@layer utilities {
  .font-display { font-family: var(--font-display); }
  .font-body    { font-family: var(--font-body); }
  .font-mono    { font-family: var(--font-mono); }

  .text-star    { color: var(--star) !important; }
  .text-muted   { color: var(--muted) !important; }
  .text-muted-2 { color: var(--muted-2) !important; }
  .text-gold    { color: var(--gold) !important; }

  .flex-center { display: flex; align-items: center; justify-content: center; }
  .flex-col    { display: flex; flex-direction: column; }

  .no-scrollbar::-webkit-scrollbar { display: none; }
}

/* ──────────────────────────────────────────────────────────
   ANIMATIONS
   ────────────────────────────────────────────────────────── */
@keyframes fade-up {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes scale-in {
  from { opacity: 0; transform: scale(.94); }
  to   { opacity: 1; transform: scale(1); }
}

.animate-fade-up  { animation: fade-up  .4s var(--ease-out) both; }
.animate-fade-in  { animation: fade-in  .35s ease both; }
.animate-scale-in { animation: scale-in .4s var(--ease-spring) both; }

.delay-100 { animation-delay: .10s; }
.delay-150 { animation-delay: .15s; }
.delay-200 { animation-delay: .20s; }
.delay-300 { animation-delay: .30s; }
.delay-400 { animation-delay: .40s; }

/* Print / PDF */
@media print {
  body { background: #fff !important; color: #000 !important; }
  .no-print { display: none !important; }
  .wheel-container { max-width: 100% !important; }
  svg text { fill: #000 !important; }
}

/* ARCHIVE-NATAL-SVG-CENTER-FIX-V2 applied */
