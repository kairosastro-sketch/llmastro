{
  "name": "@astro-platform/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.cjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup --config tsup.config.ts",
    "start": "node dist/index.cjs",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "import-cities": "tsx src/scripts/import-cities.ts"
  },
  "dependencies": {
    "@astro-platform/ephemeris": "workspace:*",
    "@astro-platform/neo4j": "workspace:*",
    "@astro-platform/types": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^4.0.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.27.0",
    "pg": "^8.11.0",
    "pg-copy-streams": "^6.0.6",
    "pino-pretty": "^13.1.3",
    "redis": "^4.6.0",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
